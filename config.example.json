    "service_defaults": {
      "calendar": "calendar-user",
      "cloud": "cloud-auth",
      "contacts": "contacts-default",
      "directory": "directory-read",
      "disk": "disk-read",
      "forms": "forms-read",
      "mail": "mail-readonly",
      "telemost": "telemost-default",
      "tracker": "tracker-read"
    },
    "catalog": {
      "mail-readonly": {
        "service": "mail",
        "app_name": "OpenClaw Yandex Mail Readonly",
        "client_id": "660686ff45f947f2ac6e3f6495a9ec74",
        "scopes": ["mail:imap_ro"],
        "omit_scope_in_url": true
      },
      "mail-readwrite": {
        "service": "mail",
        "app_name": "OpenClaw Yandex Mail ReadWrite",
        "client_id": "8d5b8d107dce4df59cdf9ca036f39865",
        "scopes": ["mail:imap_full"],
        "omit_scope_in_url": true
      },
      "disk-read": {
